#!/usr/bin/env bash
set -euo pipefail

log() { printf "[post-create] %s\n" "$*" >&2; }

USER_NAME="$(whoami 2>/dev/null || echo vscode)"
log "Running as user: $USER_NAME (HOME=$HOME)"

install_packages() {
  /usr/local/bin/mise trust -a -y
  /usr/local/bin/mise install -y
}

log "Installing packages..."
install_packages

if [ ! -d "$HOME/.local/share/zap" ]; then
  log "Cloning zap.zsh into $HOME/.local/share/zap"
  git clone -b "master" https://github.com/zap-zsh/zap.git "$HOME/.local/share/zap"
fi

log "Installation complete."

exit 0
